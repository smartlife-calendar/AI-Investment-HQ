{
  "name": "StockIQ & SmartLife - Threads Auto Post",
  "nodes": [
    {
      "id": "schedule-1",
      "name": "Daily Schedule",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [
        240,
        300
      ],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 1 * * *"
            }
          ]
        }
      }
    },
    {
      "id": "code-1",
      "name": "Get Day of Week",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        300
      ],
      "parameters": {
        "jsCode": "const now = new Date();\nconst tw = new Date(now.getTime() + 8*3600000);\nconst day = tw.getDay();\nreturn [{json: {day, isStockIQDay: day%2!==0, product: day%2!==0?'stockiq':'smartlife'}}];"
      }
    },
    {
      "id": "http-1",
      "name": "Get StockIQ Trending",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        680,
        200
      ],
      "parameters": {
        "url": "https://ai-investment-hq-production.up.railway.app/trending",
        "method": "GET"
      }
    },
    {
      "id": "http-2",
      "name": "AI Generate Post",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        900,
        300
      ],
      "parameters": {
        "url": "https://api.anthropic.com/v1/messages",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "YOUR_ANTHROPIC_API_KEY"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": {
          "model": "claude-haiku-4-5",
          "max_tokens": 350,
          "messages": [
            {
              "role": "user",
              "content": "你是台灣 Threads 用戶，今天輪到推廣其中一個產品。\n\n今日推廣：{{ $node[\"Get Day of Week\"].json.isStockIQDay ? 'StockIQ 股票分析' : 'SmartLife Calendar 行事曆' }}\n\n如果是 StockIQ：\n- 用繁體中文，80-120字，自然語氣\n- 提到 AI 股票分析、省時間、看懂趨勢\n- 連結：stockiq.tw\n- hashtag 一定要有：#Stock #美股（再加1個相關的）\n\n如果是 SmartLife Calendar：\n- 用繁體中文，80-120字，自然語氣\n- 提到時間管理、生活規劃、智慧行事曆\n- App Store：https://apps.apple.com/tw/app/smartlife-calendar/id6762165674\n- Google Play：https://play.google.com/store/apps/details?id=app.smartlifecalendar\n- hashtag 一定要有：#App #好用工具（再加1個相關的）\n\n只輸出貼文內容，不要加任何說明。"
            }
          ]
        }
      }
    },
    {
      "id": "code-2",
      "name": "Extract Post Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        300
      ],
      "parameters": {
        "jsCode": "const r = $input.first().json;\nconst text = r.content[0].text.trim();\nconst isStockIQ = $node['Get Day of Week'].json.isStockIQDay;\nlet final = text;\nif (isStockIQ && !final.includes('stockiq.tw')) final += '\\n\\n🔍 https://stockiq.tw';\nreturn [{json: {postText: final}}];"
      }
    },
    {
      "id": "http-3",
      "name": "Create Threads Container",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1340,
        300
      ],
      "parameters": {
        "url": "https://graph.threads.net/v1.0/26779577381733831/threads",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": {
          "media_type": "TEXT",
          "text": "={{ $json.postText }}",
          "access_token": "THAHZCwqhe0ZAWtBYlkwTHJ6dEhYUXVLYWVWMjVybkFQRGhORl85S3FRaWd2UjgxWHBwY0tELVp4Yk5GaE84QllidjNOLUtTaF9HLTRPVG43VEhOSndYeVdYbmkzTFB2dUI4dHVSaDl1OFhqcHFqUGY3ZAlFESjZAteHVnUHhwNFM2SlVDcW1USl9FZAUhpSmFLaHMZD"
        }
      }
    },
    {
      "id": "wait-1",
      "name": "Wait 5s",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [
        1560,
        300
      ],
      "parameters": {
        "amount": 5,
        "unit": "seconds"
      }
    },
    {
      "id": "http-4",
      "name": "Publish to Threads",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1780,
        300
      ],
      "parameters": {
        "url": "https://graph.threads.net/v1.0/26779577381733831/threads_publish",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": {
          "creation_id": "={{ $json.id }}",
          "access_token": "THAHZCwqhe0ZAWtBYlkwTHJ6dEhYUXVLYWVWMjVybkFQRGhORl85S3FRaWd2UjgxWHBwY0tELVp4Yk5GaE84QllidjNOLUtTaF9HLTRPVG43VEhOSndYeVdYbmkzTFB2dUI4dHVSaDl1OFhqcHFqUGY3ZAlFESjZAteHVnUHhwNFM2SlVDcW1USl9FZAUhpSmFLaHMZD"
        }
      }
    }
  ],
