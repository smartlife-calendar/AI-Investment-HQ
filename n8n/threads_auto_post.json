      "main": [
        [
          {
            "node": "Get Day of Week",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get Day of Week": {
      "main": [
        [
          {
            "node": "Get StockIQ Trending",
            "type": "main",
            "index": 0
          },
          {
            "node": "AI Generate Post",
            "type": "main",
            "index": 0
          }
        ]
      ]
