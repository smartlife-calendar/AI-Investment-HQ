{
  "name": "StockIQ & SmartLife - Threads Auto Post",
  "nodes": [
    {
      "id": "schedule-1",
      "name": "Daily Schedule",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [
        240,
        300
      ],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 1 * * *"
            }
          ]
        }
      }
    },
    {
      "id": "code-1",
      "name": "Get Day of Week",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        300
      ],
      "parameters": {
        "jsCode": "const now = new Date();\nconst tw = new Date(now.getTime() + 8*3600000);\nconst day = tw.getDay();\nreturn [{json: {day, isStockIQDay: day%2!==0, product: day%2!==0?'stockiq':'smartlife'}}];"
      }
    },
    {
      "id": "http-1",
      "name": "Get StockIQ Trending",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        680,
        200
      ],
      "parameters": {
        "url": "https://ai-investment-hq-production.up.railway.app/trending",
        "method": "GET"
      }
    },
    {
      "id": "http-2",
      "name": "AI Generate Post",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        900,
        300
      ],
      "parameters": {
        "url": "https://api.anthropic.com/v1/messages",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "YOUR_ANTHROPIC_API_KEY"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": {
          "model": "claude-haiku-4-5",
          "max_tokens": 300,
          "messages": [
            {
              "role": "user",
              "content": "用繁體中文寫一則自然的Threads貼文80-120字，推廣 StockIQ AI 股票分析工具，網址 https://stockiq.tw，語氣自然不像廣告，加2-3個hashtag。"
            }
          ]
        }
      }
    },
    {
      "id": "code-2",
      "name": "Extract Post Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        300
      ],
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst text = response.content[0].text.trim();\nconst finalText = text.includes('stockiq.tw') ? text : text + '\\n\\n🔍 https://stockiq.tw';\nreturn [{json: {postText: finalText}}];"
      }
    },
    {
      "id": "http-3",
      "name": "Create Threads Container",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1340,
        300
      ],
      "parameters": {
        "url": "https://graph.threads.net/v1.0/26779577381733831/threads",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": {
          "media_type": "TEXT",
          "text": "={{ $json.postText }}",
          "access_token": "THAHZCwqhe0ZAWtBYmF1RWZAfelVzdGJwMmZA1c2JPZAjdhcTRSSTVQSFBZAMHJ6Q21Na1BmOXBHVHdYN29GQjJlRElLOTVEREhXTERZAbG9jalZAhNUY1Nlhldld4UWU2RjdneW1YeFZAjNjNqU0lHRzVOUVFwSnkyUVE3SGZA4bXdQeE0xQ3RYU1lpakc3aDA5TFhqMHMZD"
        }
      }
    },
    {
      "id": "wait-1",
      "name": "Wait 5s",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [
        1560,
        300
      ],
      "parameters": {
        "amount": 5,
        "unit": "seconds"
      }
    },
    {
      "id": "http-4",
      "name": "Publish to Threads",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1780,
        300
      ],
      "parameters": {
        "url": "https://graph.threads.net/v1.0/26779577381733831/threads_publish",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": {
          "creation_id": "={{ $json.id }}",
          "access_token": "THAHZCwqhe0ZAWtBYmF1RWZAfelVzdGJwMmZA1c2JPZAjdhcTRSSTVQSFBZAMHJ6Q21Na1BmOXBHVHdYN29GQjJlRElLOTVEREhXTERZAbG9jalZAhNUY1Nlhldld4UWU2RjdneW1YeFZAjNjNqU0lHRzVOUVFwSnkyUVE3SGZA4bXdQeE0xQ3RYU1lpakc3aDA5TFhqMHMZD"
        }
      }
    }
  ],
  "connections": {
